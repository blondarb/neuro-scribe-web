# =============================================================================
# Neuro Scribe — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in all values.
# NEVER commit .env to version control.
# =============================================================================

# --- Server ---
PORT=3000
NODE_ENV=development

# --- Database (PostgreSQL) ---
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://neuroscribe:changeme@localhost:5432/neuro_scribe

# --- AWS (Bedrock + Transcribe Medical — BAA REQUIRED for PHI) ---
AWS_REGION=us-east-2
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
# Or use IAM role / SSO profile instead of explicit keys.
# The AWS SDK credential chain will resolve automatically.

# --- Authentication (OAuth 2.0 / OIDC) ---
# Auth0 example — replace with your provider
AUTH_ISSUER=https://your-tenant.auth0.com/
AUTH_AUDIENCE=neuro-scribe-api
AUTH_JWKS_URI=https://your-tenant.auth0.com/.well-known/jwks.json
JWT_SECRET=change-this-to-a-random-64-char-string

# --- Session ---
SESSION_TIMEOUT_MINUTES=15

# --- Encryption (AES-256 for PHI at rest) ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=change-this-generate-with-command-above

# --- Knowledge Base ---
PLANS_JSON_PATH=./data/plans.json
MEDICATIONS_JSON_PATH=./data/medications.json

# --- Logging ---
LOG_LEVEL=info
# NEVER set LOG_LEVEL=debug in production — risk of PHI exposure
