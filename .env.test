# =============================================================================
# Test Environment — used by vitest automatically
# =============================================================================
# No external services required. All tests use mocked/in-memory data.
# =============================================================================

NODE_ENV=test
PORT=3001

# AWS (test placeholders — tests should mock AWS SDK calls)
AWS_REGION=us-east-2
AWS_ACCESS_KEY_ID=aws-placeholder
AWS_SECRET_ACCESS_KEY=aws-placeholder

# Test encryption key (32 bytes hex = 64 chars)
# This is NOT a real key — it's only for test encryption round-trips
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# JWT (test-only, no real auth provider)
JWT_SECRET=test-secret-do-not-use-in-production-minimum-64-chars-long-padding
AUTH_ISSUER=neuro-scribe-test
AUTH_AUDIENCE=neuro-scribe-api

# Knowledge base (relative to project root)
PLANS_JSON_PATH=./data/plans.json
MEDICATIONS_JSON_PATH=./data/medications.json

# Logging (suppress in tests)
LOG_LEVEL=error

# Database (not used in unit tests — integration tests use this)
DATABASE_URL=postgresql://synapse:test@localhost:5432/neuro_scribe_test
